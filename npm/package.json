{
  "name": "libfreeform",
  "version": "0.1.0",
  "description": "Parse Apple Freeform pasteboard data: PencilKit ink, the CRLNativeData object graph, and the TSUDescription manifest. Rust compiled to WebAssembly; works in Node, Bun, Deno, and browsers.",
  "license": "(MIT OR Apache-2.0)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/can1357/libfreeform.git",
    "directory": "npm"
  },
  "homepage": "https://github.com/can1357/libfreeform#readme",
  "bugs": "https://github.com/can1357/libfreeform/issues",
  "keywords": [
    "freeform",
    "apple",
    "pasteboard",
    "clipboard",
    "pencilkit",
    "pkdrawing",
    "parser",
    "wasm"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": "./dist/index.node.js",
      "default": "./dist/index.js"
    },
    "./wasm": "./dist/libfreeform_bg.wasm"
  },
  "files": [
    "dist",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "node build.mjs"
  }
}
